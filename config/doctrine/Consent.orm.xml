<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping
    xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd"
>
    <entity name="App\Domain\Lead\Consent" table="consent">
        <id name="id" type="integer" column="id">
            <generator strategy="AUTO"/>
        </id>

        <field name="scope" type="string" length="100"/>
        <field name="policyVersion" type="string" length="50"/>
        <field name="givenAt" type="datetime_immutable"/>
        <field name="source" type="string" length="100"/>
        <field name="ipAddress" type="string" length="45" nullable="true"/>

        <many-to-one field="lead" target-entity="App\Domain\Lead\Lead" inversed-by="consents">
            <join-column name="lead_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>
    </entity>
</doctrine-mapping>
